---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { dateRange } from "@/lib/utils";
import { useTranslations } from "@/i18n/utils";

export async function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params;
const t = useTranslations(lang as "en" | "es");

const collection = (await getCollection("work")).sort(
  (a, b) =>
    new Date(b.data.dateStart).valueOf() - new Date(a.data.dateStart).valueOf(),
);

const work = await Promise.all(
  collection
    .filter((item) => item.data.lang === lang)
    .map(async (item) => {
      const { Content } = await item.render();
      return { ...item, Content };
    }),
);

const slugify = (str: string) => str.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
---

<Layout title={t("work.title")} description={t("work.description")}>
  <div class="mx-auto px-4 md:px-6 max-w-7xl">
    <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-8">

      <!-- ═══════ Sidebar: Company list ═══════ -->
      <aside class="order-2 lg:order-1 lg:sticky lg:top-28 lg:self-start">
        <p class="font-display text-[0.65rem] text-text-200/40 uppercase tracking-widest mb-3">
          {t("work.title")}
        </p>
        {work.length > 0 && (
          <nav class="flex flex-col gap-1">
            {work.map((entry) => (
              <a
                href={`#${slugify(entry.data.company)}`}
                data-ph-click="work_sidebar_clicked"
                data-ph-company={entry.data.company}
                class="group block px-3 py-2.5 rounded-lg border border-transparent transition-all duration-200 hover:border-bg-300/60 hover:bg-bg-200/60"
              >
                <span class="font-display text-[0.78rem] font-bold text-text-200/70 leading-snug block transition-colors group-hover:text-text-100">
                  {entry.data.company}
                </span>
                <span class="font-display text-[0.6rem] text-primary-100/50 block mt-0.5">
                  {entry.data.role}
                </span>
              </a>
            ))}
          </nav>
        )}
      </aside>

      <!-- ═══════ Main: Work entries ═══════ -->
      <main class="order-1 lg:order-2 min-w-0">
        <div class="max-w-3xl">
          {work.length === 0 ? (
            <div class="p-8 border border-dashed border-bg-300/50 rounded-xl text-text-200/40 text-sm text-center font-display animate">
              {t("empty.work")}
            </div>
          ) : (
            <div class="flex flex-col gap-10">
              {work.map((entry, i) => (
                <div
                  id={slugify(entry.data.company)}
                  class="scroll-mt-32 animate"
                >
                  <!-- Header -->
                  <div class="flex flex-wrap items-start justify-between gap-x-4 gap-y-2 mb-4">
                    <div>
                      <h2 class="font-display font-bold text-text-100 text-xl">
                        {entry.data.company}
                      </h2>
                      <p class="text-text-200/60 text-[0.85rem] mt-0.5">
                        {entry.data.role}
                      </p>
                    </div>
                    <span class="font-display text-[0.7rem] text-primary-100 bg-primary-100/10 px-3 py-1 rounded-full whitespace-nowrap">
                      {dateRange(entry.data.dateStart, entry.data.dateEnd)}
                    </span>
                  </div>

                  <!-- Content -->
                  <article class="text-sm prose prose-invert prose-headings:font-display prose-headings:text-text-100 max-w-none">
                    <entry.Content />
                  </article>

                  <!-- Divider -->
                  {i < work.length - 1 && (
                    <div class="mt-10 border-t border-bg-300/30" />
                  )}
                </div>
              ))}
            </div>
          )}
        </div>
      </main>

    </div>
  </div>
</Layout>
